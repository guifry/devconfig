#!/bin/bash

# tmux is for SSH sessions only. Local terminal uses Ghostty.

cat << 'EOF'
TMUX HOTKEYS (prefix = Ctrl+]) — SSH sessions only

WINDOWS
───────────────────────────────────
New window          prefix + c
Next window         prefix + n
Previous window     prefix + p
Switch to window N  prefix + 0-9
Rename window       prefix + ,
List windows        prefix + w
Insert window       prefix + I  (custom, shifts others right)

SESSIONS
───────────────────────────────────
New session         prefix + :new
Detach              prefix + d
Switch (interactive) prefix + s
Next session        prefix + )
Previous session    prefix + (
Rename session      prefix + $

PANES
───────────────────────────────────
Split vertical      prefix + %
Split horizontal    prefix + "
Navigate            prefix + h/j/k/l  (custom)
Resize              prefix + H/J/K/L  (custom, repeatable)
Equalise (tiled)    prefix + e  (custom)
Cycle layouts       prefix + Space
Rotate panes fwd    prefix + Ctrl+o
Swap with prev      prefix + {
Swap with next      prefix + }
Set pane label      prefix + T  (custom)
Clear pane label    prefix + t  (custom)

COPY MODE (vi)
───────────────────────────────────
Enter copy mode     prefix + [
Start selection     v
Copy & exit         y  or  Enter
Scroll up/down      Ctrl+u / Ctrl+d

PERSISTENCE (tmux-resurrect + continuum)
───────────────────────────────────
Save state          prefix + S     (all sessions, windows, panes, workdirs)
Restore state       prefix + Ctrl+r
Auto-save           every 15 min
Auto-restore        on tmux start

CLAUDE CODE SCROLLBACK (custom)
───────────────────────────────────
Jump to my msg      prefix + /     (❯ user messages)
Jump to Claude msg  prefix + ?     (⏺ assistant responses)
Jump to shell ➜     prefix + .     (shell prompts)
Repeat search       n / N          (forward / backward)
Yank Claude reply   prefix + y     (last ⏺ block to clipboard)

PLUGINS
───────────────────────────────────
Thumbs (copy text)  prefix + f
EOF
